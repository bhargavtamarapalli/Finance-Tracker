        android:strokeColor="#FFFFFF"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000" />

    <!-- Stylized Upward Glow Trend Chart Arrow weaving through the coin -->
    <path
        android:pathData="M25,85 L45,70 L65,75 L95,35"
        android:strokeWidth="6"
        android:strokeColor="#03DAC6"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000" />

    <path
        android:pathData="M83,35 L95,35 L95,47"
        android:strokeWidth="6"
        android:strokeColor="#03DAC6"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000" />

    <!-- A brighter overlay stroke for premium neon contrast -->
    <path
        android:pathData="M25,85 L45,70 L65,75 L95,35"
        android:strokeWidth="3"
        android:strokeColor="#FFFFFF"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000" />

    <path
        android:pathData="M83,35 L95,35 L95,47"
        android:strokeWidth="3"
        android:strokeColor="#FFFFFF"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
