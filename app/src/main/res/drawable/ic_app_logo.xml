        android:strokeWidth="1.5"
        android:strokeColor="#66FFFFFF"
        android:strokeLineCap="round"
        android:fillColor="#00000000" />

    <!-- Dollar Sign or Coin Accent in center -->
    <path
        android:pathData="M60,48 L60,72 M55,53 C55,53 58,50 60,50 C63,50 65,52 65,55 C65,58 62,59 60,60 C57,61 55,62 55,65 C55,68 58,70 61,70 C63,70 65,68 65,68 M60,48"
