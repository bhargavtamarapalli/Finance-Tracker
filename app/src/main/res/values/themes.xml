<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <!-- Set the splash screen background, animated icon, and animation duration. -->
        <item name="windowSplashScreenBackground">#0B0E14</item>
        <!-- Use clear theme colors and standard theme as post-splash -->
        <item name="postSplashScreenTheme">@style/Theme.MyApplication</item>
    </style>

    <style name="Theme.MyApplication" parent="android:Theme.DeviceDefault.NoActionBar" />
</resources>
