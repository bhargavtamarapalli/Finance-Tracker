{
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "strict": false,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@finance/shared": ["shared/src/index"],
      "@finance/shared/*": ["shared/src/*"]
    }
  }
}
